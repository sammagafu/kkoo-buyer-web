# KKOO Buyer Web — local development
# Local dev: Vite proxies /api → backend (see vite.config.ts)
VITE_API_BASE_URL=/api/v1
# Production: https://api.kkooapp.co.tz/api/v1 (set in .env.production or Docker build arg)

# Business portal (separate kkoo-biz-web app)
VITE_BIZ_WEB_ORIGIN=http://localhost:5174

